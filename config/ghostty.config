theme = carbonfox

background-opacity=0.9
background-blur=true
# background = 3B3D4E
font-family = "Hack Nerd Font Mono"
font-size = 19
window-padding-x = 20
window-padding-y = 20
window-padding-balance = true
window-save-state = always
shell-integration = zsh
scrollbar = never

#macos-icon = xray
macos-icon = custom
macos-custom-icon = /Users/maybequantum/.config/ghostty/ghostty-black.icns
#macos-icon-frame = aluminum
#macos-icon-ghost-color = #47474E
#macos-icon-screen-color = #FFFFFF

macos-titlebar-style = transparent
window-colorspace = display-p3

# Shaders
#custom-shader = /Users/maybequantum/Library/Application Support/com.mitchellh.ghostty/glitchy.glsl
#custom-shader-animation = true

keybind = cmd+s>r=reload_config

copy-on-select = clipboard
auto-update = off
